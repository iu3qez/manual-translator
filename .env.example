MISTRAL_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODELS=anthropic/claude-3.5-sonnet, google/gemini-2.0-flash-001
# OCR model: ocr4 (mistral-ocr-latest, default — gives blocks for layout) or ocr3 (cheaper, flat)
OCR_MODEL=mistral-ocr-latest
OUTPUT_FORMATS=pdf,docx
# (header/footer policy is set in glossary.yaml, not here)
# MODEL_ATTEMPTS = full passes over the model list before giving up on a page.
# Any failure (429 rate limit / 5xx / timeout) falls back to the next model
# immediately; a backoff happens only between full passes.
MODEL_ATTEMPTS=2
# Pages translated in parallel (OpenRouter). Lower if you hit rate limits.
TRANSLATE_CONCURRENCY=8
CACHE_DIR=.cache
